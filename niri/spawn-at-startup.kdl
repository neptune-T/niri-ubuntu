// Spawn processes at niri startup.
// https://github.com/YaLTeR/niri/wiki/Configuration:-Miscellaneous#spawn-sh-at-startup
spawn-sh-at-startup "command -v udiskie >/dev/null 2>&1 && udiskie"
spawn-sh-at-startup "$NIRICONF/scripts/start-polkit-agent.sh"
spawn-sh-at-startup "wl-paste --watch cliphist store"
spawn-sh-at-startup "waybar -c $NIRICONF/waybar/config -s $NIRICONF/waybar/style.css"
spawn-sh-at-startup "dunst -conf $NIRICONF/dunst/dunstrc"
spawn-sh-at-startup "state_dir=${XDG_STATE_HOME:-$HOME/.local/state}; mkdir -p \"$state_dir\"; [ -f \"$state_dir/idle-time\" ] || echo '10 minutes' > \"$state_dir/idle-time\"; pkill -x swayidle || true; $NIRICONF/scripts/swayidle.sh"
